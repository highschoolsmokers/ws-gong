{
  "crons": [
    {
      "path": "/api/discover-sources",
      "schedule": "0 9 * * 0"
    },
    {
      "path": "/api/mine",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/api/prune-logs",
      "schedule": "0 10 1 * *"
    },
    {
      "path": "/api/heartbeat",
      "schedule": "0 10 * * *"
    }
  ],
  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- ':(exclude)*.md' ':(exclude)docs/**' ':(exclude).github/**' ':(exclude).husky/**' ':(exclude)TODO.md' ':(exclude)README.md' ':(exclude).prettierignore' ':(exclude)lib/**/*.test.ts'"
}
